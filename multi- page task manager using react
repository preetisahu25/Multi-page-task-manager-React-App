// ─── App ─────────────────────────────────────────────────────────
export default function App() {
  const [tasks, setTasks] = useState(() => {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || initialTasks; }
    catch { return initialTasks; }
  });

  useEffect(() => {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(tasks)); } catch {}
  }, [tasks]);

  const { pathname, params, navigate } = useRouter();
  const { toasts, show: showToast } = useToast();

  // Inject CSS
  useEffect(() => {
    const el = document.createElement("style");
    el.textContent = css;
    document.head.appendChild(el);
    return () => el.remove();
  }, []);

  const renderPage = () => {
    if (pathname === "/") return <HomePage tasks={tasks} navigate={navigate} />;
    if (pathname === "/tasks") return <TasksPage tasks={tasks} setTasks={setTasks} navigate={navigate} params={params} showToast={showToast} />;
    if (pathname.startsWith("/tasks/")) {
      const id = pathname.replace("/tasks/", "");
      return <TaskDetailPage tasks={tasks} setTasks={setTasks} navigate={navigate} id={id} showToast={showToast} />;
    }
    if (pathname === "/about") return <AboutPage />;
    return <NotFoundPage navigate={navigate} />;
  };

  return (
    <div className="app">
      <nav className="nav">
        <div className="nav-inner">
          <span className="nav-brand" onClick={() => navigate("/")}>
            task<span>.</span>
          </span>
          <div className="nav-links">
            <NavLink to="/" navigate={navigate} pathname={pathname}>Home</NavLink>
            <NavLink to="/tasks" navigate={navigate} pathname={pathname}>Tasks</NavLink>
            <NavLink to="/about" navigate={navigate} pathname={pathname}>About</NavLink>
          </div>
        </div>
      </nav>

      <main className="main">
        {renderPage()}
      </main>

      <div className="toast-wrap">
        {toasts.map(t => <div key={t.id} className="toast">{t.msg}</div>)}
      </div>
    </div>
  );
}
