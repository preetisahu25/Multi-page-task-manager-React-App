function TasksPage({ tasks, setTasks, navigate, params, showToast }) {
  const filter = params.get("filter") || "all";

  const filteredTasks = tasks.filter(t => {
    if (filter === "active") return t.status === "active";
    if (filter === "completed") return t.status === "completed";
    if (filter === "high") return t.priority === "high";
    return true;
  });

  const counts = {
    all: tasks.length,
    active: tasks.filter(t => t.status === "active").length,
    completed: tasks.filter(t => t.status === "completed").length,
    high: tasks.filter(t => t.priority === "high").length,
  };

  const toggleDone = (e, id) => {
    e.stopPropagation();
    setTasks(prev => prev.map(t => {
      if (t.id !== id) return t;
      const next = t.status === "completed" ? "active" : "completed";
      showToast(next === "completed" ? "Task marked complete ✓" : "Task reopened");
      return { ...t, status: next };
    }));
  };

  const setFilter = (f) => navigate(f === "all" ? "/tasks" : `/tasks?filter=${f}`);

  return (
    <div>
      <div className="page-header">
        <h1 className="page-title">Tasks</h1>
        <p className="page-sub">Click a task to view details. Toggle the checkbox to complete it.</p>
      </div>

      <div className="filter-bar">
        {["all", "active", "completed", "high"].map(f => (
          <button
            key={f}
            className={`filter-btn${filter === f ? " active" : ""}`}
            onClick={() => setFilter(f)}
          >
            {f.charAt(0).toUpperCase() + f.slice(1)}
            <span className="filter-count">{counts[f]}</span>
          </button>
        ))}
        {filter !== "all" && (
          <span style={{ fontSize: 12, color: "var(--text-3)", fontFamily: "'DM Mono', monospace", marginLeft: 4 }}>
            ?filter={filter}
          </span>
        )}
      </div>

      <div className="tasks-header">
        <span className="tasks-count">{filteredTasks.length} task{filteredTasks.length !== 1 ? "s" : ""}</span>
      </div>

      {filteredTasks.length === 0 ? (
        <div className="empty-state">
          <div className="empty-icon">📭</div>
          <div className="empty-title">No tasks here</div>
          <div className="empty-desc">Try a different filter or check back later.</div>
        </div>
      ) : (
        <div className="task-list">
          {filteredTasks.map(task => (
            <div
              key={task.id}
              className={`task-card${task.status === "completed" ? " done" : ""}`}
              onClick={() => navigate(`/tasks/${task.id}`)}
            >
              <button
                className={`task-check${task.status === "completed" ? " checked" : ""}`}
                onClick={e => toggleDone(e, task.id)}
                title={task.status === "completed" ? "Mark active" : "Mark complete"}
              />
              <div className="task-body">
                <div className="task-title">{task.title}</div>
                <div className="task-desc-preview">{task.description}</div>
                <div className="task-meta">
                  <span className={`badge badge-${task.priority}`}>{task.priority}</span>
                  <span className={`badge badge-${task.status === "completed" ? "done" : "active"}`}>
                    {task.status}
                  </span>
                  <span className="task-date">{task.created}</span>
                </div>
              </div>
              <span className="task-arrow">→</span>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

function TaskDetailPage({ tasks, setTasks, navigate, id, showToast }) {
  const task = tasks.find(t => t.id === id);

  if (!task) {
    return (
      <div>
        <button className="back-btn" onClick={() => navigate("/tasks")}>← Back to tasks</button>
        <div className="not-found" style={{ padding: "40px 0" }}>
          <div className="not-found-code" style={{ fontSize: 64 }}>404</div>
          <div className="not-found-title">Task not found</div>
          <div className="not-found-desc">No task with ID #{id} exists.</div>
          <button className="btn btn-primary" onClick={() => navigate("/tasks")}>Back to tasks</button>
        </div>
      </div>
    );
  }

  const toggle = () => {
    setTasks(prev => prev.map(t => {
      if (t.id !== task.id) return t;
      const next = t.status === "completed" ? "active" : "completed";
      showToast(next === "completed" ? "Marked as complete ✓" : "Task reopened");
      return { ...t, status: next };
    }));
  };

  return (
    <div>
      <button className="back-btn" onClick={() => navigate("/tasks")}>← Back to tasks</button>

      <div className="detail-card">
        <div className="detail-header">
          <div className="detail-eyebrow">
            <span className="badge badge-id" style={{ background: "rgba(255,255,255,0.08)", color: "#8a8278" }}>#{task.id}</span>
          </div>
          <div className="detail-title">{task.title}</div>
          <div className="detail-badges">
            <span className={`badge badge-${task.priority}`}>{task.priority} priority</span>
            <span className={`badge badge-${task.status === "completed" ? "done" : "active"}`}>{task.status}</span>
          </div>
        </div>

        <div className="detail-body">
          <div className="detail-section">
            <div className="detail-section-label">Description</div>
            <div className="detail-section-value">{task.description}</div>
          </div>

          <div className="detail-grid">
            <div className="detail-section">
              <div className="detail-section-label">Created</div>
              <div className="detail-section-value">{task.created}</div>
            </div>
            <div className="detail-section">
              <div className="detail-section-label">Route</div>
              <div className="detail-section-value" style={{ fontFamily: "'DM Mono', monospace", fontSize: 13 }}>/tasks/{task.id}</div>
            </div>
          </div>

          <div className="detail-actions">
            <button className={`btn ${task.status === "completed" ? "" : "btn-success"}`} onClick={toggle}>
              {task.status === "completed" ? "↩ Reopen task" : "✓ Mark complete"}
            </button>
            <button className="btn" onClick={() => navigate("/tasks")}>← All tasks</button>
          </div>
        </div>
      </div>
    </div>
  );
}

